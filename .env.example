# ============================================================
# OpenBB Dashboard — root .env template
# ============================================================
# Copy this file to `.env` in the same directory and fill in
# the values. The root .env is consumed by docker-compose.yml
# when you run `docker compose up` for local development.
#
# DO NOT commit the resulting .env. It is gitignored.
# Set file permissions to 600 on any machine where it lives:
#   chmod 600 .env
# ============================================================


# ---- Data providers (required for most dashboard features) ----

# Financial Modeling Prep — fundamentals, key metrics, earnings
# Free tier available. Get your key at:
#   https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Tiingo — news articles for equity tickers
# Free tier available. Get your token at:
#   https://api.tiingo.com
TIINGO_API_KEY=

# FRED (Federal Reserve Economic Data) — macro series
# Free. Get your key at:
#   https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=


# ---- AI analysis (OPTIONAL) ----

# Powers the "Analisi AI" button on the equity detail page
# (frontend/app/api/analyze/route.ts). Leave empty to disable
# that feature — the rest of the dashboard works without it.
#
# NOTE: this is a pay-per-use Anthropic API key, NOT your Claude
# Pro/Max subscription. Before setting it, configure a monthly
# spending cap on https://console.anthropic.com/settings/limits
# to protect against unexpected usage if the key is ever leaked.
ANTHROPIC_API_KEY=
