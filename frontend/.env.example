# URL Domain API — used by next.config.mjs proxy rewrite and lib/openbb.ts server-side
DOMAIN_API_URL=http://localhost:6901

# Required for AI analysis (/api/analyze route)
ANTHROPIC_API_KEY=sk-ant-...

# Note: OpenBB Platform (:6900) is no longer required.
# All data comes from the Domain API (:6901) which calls yfinance/FMP/Tiingo/FRED directly.
